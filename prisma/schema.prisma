generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(GURU)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Berita {
  id        String   @id @default(cuid())
  judul     String
  pj        String?
  tanggal   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dokumen {
  id        String   @id @default(cuid())
  nama      String
  link      String
  kategori  String   @default("Umum")
  aksesRole String   @default("KEPALA,GURU")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Catatan {
  id        String   @id @default(cuid())
  tanggal   DateTime
  judul     String
  catatan   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  KEPALA
  GURU
}
